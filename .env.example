# ============================================================================
#  realestate-editorial-agents — Plantilla de configuración
#  Copiá este archivo a `.env` y completá los valores. NUNCA commitees `.env`.
# ============================================================================

# --- Claude / Anthropic (OBLIGATORIO) -------------------------------------
# API key de la plataforma Claude: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Modelos por agente (opcional; estos son los valores por defecto) ------
# IDs válidos: claude-opus-4-8, claude-sonnet-4-6, claude-haiku-4-5
MODEL_SCOUT=claude-opus-4-8
MODEL_CURATOR=claude-sonnet-4-6
MODEL_FACT_CHECKER=claude-opus-4-8
MODEL_WRITER=claude-opus-4-8
MODEL_CRITIC=claude-opus-4-8
MODEL_ILLUSTRATOR=claude-sonnet-4-6
MODEL_SOCIAL=claude-sonnet-4-6

# --- Línea editorial -------------------------------------------------------
REGION_FOCUS=Argentina y Latinoamérica
LANGUAGES=es
NUM_TOPICS=4                 # cuántas noticias selecciona el curador
MAX_REVISIONS=2              # iteraciones máximas writer<->critic
MIN_SOURCES_PER_CLAIM=2      # fuentes independientes mínimas por dato clave
BLOG_NAME=Real Estate Insights

# --- Generación de imágenes (opcional) -------------------------------------
# IMAGE_PROVIDER: openai | none
#   openai -> usa el modelo gpt-image-1 (requiere OPENAI_API_KEY)
#   none   -> no genera imágenes (escribe sólo el brief y alt-text)
IMAGE_PROVIDER=none
OPENAI_API_KEY=
IMAGE_SIZE=1536x1024

# --- Blog: WordPress REST API ----------------------------------------------
# El usuario te pasará estas credenciales. La "app password" se genera en
# WordPress -> Usuarios -> Perfil -> Contraseñas de aplicación.
WORDPRESS_URL=https://tu-blog.com
WORDPRESS_USER=editor
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WORDPRESS_STATUS=draft       # draft | publish | pending

# --- Redes sociales: upload-post.com ---------------------------------------
# API key: https://www.upload-post.com/  (panel -> API)
UPLOADPOST_API_KEY=
UPLOADPOST_USER=tu_usuario_uploadpost
# Plataformas separadas por coma: tiktok,instagram,linkedin,facebook,x,threads
SOCIAL_PLATFORMS=instagram,linkedin,facebook,x

# --- Seguridad / ejecución -------------------------------------------------
# DRY_RUN=true  -> genera todo pero NO publica (recomendado para probar)
# DRY_RUN=false -> publica de verdad en blog y redes
DRY_RUN=true
OUTPUT_DIR=output
