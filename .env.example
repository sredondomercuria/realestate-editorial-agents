# ============================================================================
#  realestate-editorial-agents — Plantilla de configuración
#  Copiá este archivo a `.env` y completá los valores. NUNCA commitees `.env`.
# ============================================================================

# --- Claude / Anthropic (OBLIGATORIO) -------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Runtime de los agentes ------------------------------------------------
# hybrid -> la "redacción autónoma" corre como Managed Agent en la plataforma
#           de Claude (Anthropic); el resto del pipeline en LangGraph (acá).
# local  -> todo corre como nodos LangGraph en este backend (no usa Managed Agents).
# Si AGENT_RUNTIME=hybrid pero falta acceso a Managed Agents, cae a 'local' solo.
AGENT_RUNTIME=hybrid
# IDs cacheados (se crean una vez con: python -m editorial_team.integrations.managed_agents)
MANAGED_AGENT_ID=
MANAGED_ENV_ID=

# --- Modelos por agente (opcional) -----------------------------------------
MODEL_SCOUT=claude-opus-4-8
MODEL_CURATOR=claude-sonnet-4-6
MODEL_FACT_CHECKER=claude-opus-4-8
MODEL_WRITER=claude-opus-4-8
MODEL_CRITIC=claude-opus-4-8
MODEL_ILLUSTRATOR=claude-sonnet-4-6
MODEL_SOCIAL=claude-sonnet-4-6

# --- Línea editorial -------------------------------------------------------
REGION_FOCUS=Argentina y Latinoamérica
LANGUAGES=es
NUM_TOPICS=4
MAX_REVISIONS=2
MIN_SOURCES_PER_CLAIM=2
BLOG_NAME=Real Estate Insights

# --- Investigación / búsqueda ----------------------------------------------
# RESEARCH_BACKEND: claude (web_search/web_fetch) | tavily
RESEARCH_BACKEND=claude
TAVILY_API_KEY=

# --- Imágenes ---------------------------------------------------------------
# IMAGE_PROVIDER:
#   gemini -> AI Studio (key GEMINI_API_KEY, crédito prepago)
#   vertex -> Vertex AI en tu proyecto GCP (factura por GCP; en Cloud Run sin key,
#             local con `gcloud auth application-default login`)
#   openai -> gpt-image-1   ·   none -> no genera
IMAGE_PROVIDER=gemini
# Con gemini: gemini-3-pro-image | gemini-3.1-flash-image | gemini-2.5-flash-image
# Con vertex: imagen-4.0-generate-001 | imagen-4.0-fast-generate-001 | gemini-2.5-flash-image
IMAGE_MODEL=gemini-3-pro-image
GEMINI_API_KEY=
OPENAI_API_KEY=
IMAGE_SIZE=1536x1024
# Vertex AI (si IMAGE_PROVIDER=vertex). Usa GCP_PROJECT de abajo.
VERTEX_LOCATION=global

# --- Hosting de imágenes (CDN) ---------------------------------------------
# IMAGE_HOST: cloudinary | none
IMAGE_HOST=none
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# --- Blog: WordPress REST API ----------------------------------------------
WORDPRESS_URL=https://tu-blog.com
WORDPRESS_USER=editor
WORDPRESS_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
WORDPRESS_STATUS=draft

# --- Redes sociales: upload-post.com ---------------------------------------
UPLOADPOST_API_KEY=
UPLOADPOST_USER=tu_usuario_uploadpost
SOCIAL_PLATFORMS=instagram,linkedin,facebook,x

# --- Persistencia ----------------------------------------------------------
# Local: SQLite. En Cloud Run el FS es efímero -> usá Cloud SQL/Firestore o un
# volumen GCS para producción (ver docs/10-deploy-gcp.md).
DATABASE_PATH=output/editorial.db

# --- Webapp / UI -----------------------------------------------------------
PORT=8080
# Token para proteger el endpoint /tasks/run-daily (lo usa Cloud Scheduler).
SCHEDULER_TOKEN=

# --- GCP -------------------------------------------------------------------
# USE_GCP_SECRETS=true -> al iniciar, carga secretos desde Secret Manager.
USE_GCP_SECRETS=false
GCP_PROJECT=supple-framing-498515-a0

# --- Seguridad / ejecución -------------------------------------------------
# DRY_RUN=true  -> genera todo pero NO publica (recomendado para probar).
DRY_RUN=true
OUTPUT_DIR=output
